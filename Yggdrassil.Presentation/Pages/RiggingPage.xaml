<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Yggdrassil.Presentation.Pages.RiggingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Yggdrassil.Presentation.Models"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="RigSectionExpanderStyle" TargetType="Expander">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="RigSlotAssignedFieldStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource AppPanelSubtleBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource AppPanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <DataTemplate x:Key="RigSlotRowTemplate" x:DataType="models:RigSlotEditorItem">
            <Grid Margin="0,0,0,8" ColumnSpacing="12" ToolTipService.ToolTip="{x:Bind LogicalBone}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Style="{StaticResource BodyStrongTextStyle}"
                    Text="{x:Bind DisplayName}" />
                <Border
                    Grid.Column="1"
                    Style="{StaticResource RigSlotAssignedFieldStyle}"
                    ToolTipService.ToolTip="{x:Bind AssignedBoneDisplay}">
                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="{x:Bind AssignedBoneDisplay}"
                        HorizontalAlignment="Right"
                        TextAlignment="Right"
                        TextWrapping="NoWrap"
                        TextTrimming="CharacterEllipsis" />
                </Border>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="RigSlotSectionTemplate" x:DataType="models:RigSlotSectionItem">
            <Expander IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}" Style="{StaticResource RigSectionExpanderStyle}">
                <Expander.Header>
                    <Grid HorizontalAlignment="Stretch" MinHeight="20">
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            FontSize="12"
                            FontWeight="Normal"
                            Text="{x:Bind Title}" />
                    </Grid>
                </Expander.Header>
                <Border Style="{StaticResource SubtlePanelBorderStyle}" Padding="12">
                    <ItemsControl ItemTemplate="{StaticResource RigSlotRowTemplate}" ItemsSource="{x:Bind Slots}" />
                </Border>
            </Expander>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Border x:Name="NoProjectPanel" Style="{StaticResource PanelBorderStyle}" Padding="20">
            <StackPanel Padding="24" Spacing="20">
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Rigging" />
                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="No project is currently active. Create or open one from the Home page." />
                </StackPanel>
            </StackPanel>
        </Border>

        <!--Panel shown if project exists-->
        <Grid x:Name="RiggingSettingsPanel" Padding="24" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="6">
                <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Rigging" />
                <TextBlock
                    Style="{StaticResource CaptionTextStyle}"
                    Text="Map imported bones onto the Source rig slots and inspect the imported armature structure." />
            </StackPanel>

            <Grid Grid.Row="1" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--Our actual bones-->
                    <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Padding="20">
                        <Grid RowSpacing="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource SectionTitleTextStyle}" Text="Bone Hierarchy" />

                            <Border x:Name="NoSkeletonPanel" Grid.Row="1" Style="{StaticResource SubtlePanelBorderStyle}" Padding="16">
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="No imported skeleton is currently available. Import a model to inspect and assign bones." />
                            </Border>

                            <ScrollViewer x:Name="BoneHierarchyScrollViewer" Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="BoneHierarchyPanel" Spacing="16">

                                    <Border Style="{StaticResource SubtlePanelBorderStyle}" Padding="16">
                                        <Grid ColumnSpacing="12" RowSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <ComboBox
                                                Grid.Row="1"
                                                Grid.Column="0"
                                                Header="Assign Selected Bone To Slot"
                                                PlaceholderText="Select a slot" />
                                            <Button
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                VerticalAlignment="Bottom"
                                                Content="Assign" />
                                        </Grid>
                                    </Border>

                                    <TreeView x:Name="BoneHierarchyTreeView" MinHeight="600" CanReorderItems="False" CanDragItems="True">
                                        <TreeView.RootNodes>
                                            <TreeViewNode Content="Root Bone">
                                                <TreeViewNode.Children>
                                                    <TreeViewNode Content="Spine" />
                                                    <TreeViewNode Content="Left Arm" />
                                                    <TreeViewNode Content="Right Arm" />
                                                </TreeViewNode.Children>
                                            </TreeViewNode>
                                        </TreeView.RootNodes>
                                    </TreeView>

                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!--List of slots-->
                    <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Padding="20">
                        <Grid RowSpacing="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource SectionTitleTextStyle}" Text="Rig Slots" />

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl
                                    MinHeight="600"
                                    ItemTemplate="{StaticResource RigSlotSectionTemplate}"
                                    ItemsSource="{x:Bind SlotSections, Mode=OneWay}" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
