<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Yggdrassil.Presentation.Dialogs.CreateProjectDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    PrimaryButtonText="Create"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <StackPanel Spacing="16">
        <StackPanel Spacing="6">
            <TextBlock Text="Project Name" />
            <TextBox x:Name="ProjectNameTextBox" PlaceholderText="MyProject" />
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="Project Directory" />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox
                    x:Name="ProjectDirectoryTextBox"
                    Grid.Column="0"
                    PlaceholderText="Choose a folder" />

                <Button
                    Grid.Column="1"
                    Click="BrowseFolderButton_Click"
                    Content="Browse" />
            </Grid>
        </StackPanel>
    </StackPanel>

</ContentDialog>
