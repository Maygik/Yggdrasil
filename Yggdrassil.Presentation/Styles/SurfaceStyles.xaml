<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="AppPanelBackgroundBrush" Color="#FFF7F7F8" />
            <SolidColorBrush x:Key="AppPanelSecondaryBackgroundBrush" Color="#FFEEEEF0" />
            <SolidColorBrush x:Key="AppPanelSubtleBackgroundBrush" Color="#FFF1F2F4" />
            <SolidColorBrush x:Key="AppPanelBorderBrush" Color="#FFD2D5DA" />
            <SolidColorBrush x:Key="AppSelectionBackgroundBrush" Color="#FFE9F2FF" />
            <SolidColorBrush x:Key="AppSelectionBorderBrush" Color="#FF4C8BF5" />
            <SolidColorBrush x:Key="AppValidationErrorBackgroundBrush" Color="#FFFBEAEC" />
            <SolidColorBrush x:Key="AppValidationErrorBorderBrush" Color="#FFD94B63" />
            <SolidColorBrush x:Key="AppValidationErrorForegroundBrush" Color="#FF8E2133" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="AppPanelBackgroundBrush" Color="#FF202124" />
            <SolidColorBrush x:Key="AppPanelSecondaryBackgroundBrush" Color="#FF2A2C31" />
            <SolidColorBrush x:Key="AppPanelSubtleBackgroundBrush" Color="#FF25272B" />
            <SolidColorBrush x:Key="AppPanelBorderBrush" Color="#FF3D4148" />
            <SolidColorBrush x:Key="AppSelectionBackgroundBrush" Color="#FF213246" />
            <SolidColorBrush x:Key="AppSelectionBorderBrush" Color="#FF8AB4FF" />
            <SolidColorBrush x:Key="AppValidationErrorBackgroundBrush" Color="#FF3D2328" />
            <SolidColorBrush x:Key="AppValidationErrorBorderBrush" Color="#FFFF7085" />
            <SolidColorBrush x:Key="AppValidationErrorForegroundBrush" Color="#FFFFC0C9" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Default">
            <SolidColorBrush x:Key="AppPanelBackgroundBrush" Color="#FFF7F7F8" />
            <SolidColorBrush x:Key="AppPanelSecondaryBackgroundBrush" Color="#FFEEEEF0" />
            <SolidColorBrush x:Key="AppPanelSubtleBackgroundBrush" Color="#FFF1F2F4" />
            <SolidColorBrush x:Key="AppPanelBorderBrush" Color="#FFD2D5DA" />
            <SolidColorBrush x:Key="AppSelectionBackgroundBrush" Color="#FFE9F2FF" />
            <SolidColorBrush x:Key="AppSelectionBorderBrush" Color="#FF4C8BF5" />
            <SolidColorBrush x:Key="AppValidationErrorBackgroundBrush" Color="#FFFBEAEC" />
            <SolidColorBrush x:Key="AppValidationErrorBorderBrush" Color="#FFD94B63" />
            <SolidColorBrush x:Key="AppValidationErrorForegroundBrush" Color="#FF8E2133" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <Style x:Key="PanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AppPanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style x:Key="SubtlePanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AppPanelSecondaryBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppPanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

</ResourceDictionary>
