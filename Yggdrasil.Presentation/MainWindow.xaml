<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Yggdrasil.Presentation.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Yggdrasil.Presentation"
    xmlns:rendering="using:Yggdrasil.Presentation.Rendering"
    xmlns:pages="using:Yggdrasil.Presentation.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <NavigationView
        x:Name="MainNavigationView"
        IsBackButtonVisible="Auto"
        IsSettingsVisible="False"
        PaneDisplayMode="Left"
        SelectionChanged="MainNavigationView_SelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="HomeNavigationItem" Content="Home" Tag="home" />
            <NavigationViewItem x:Name="ProjectNavigationItem" Content="Project" Tag="project" />
            <NavigationViewItem x:Name="ModelNavigationItem" Content="Model" Tag="model" />
            <NavigationViewItem x:Name="MaterialsNavigationItem" Content="Materials" Tag="materials" />
            <NavigationViewItem x:Name="RiggingNavigationItem" Content="Rigging" Tag="rigging" />
            <NavigationViewItem x:Name="ViewportNavigationItem" Content="Viewport" Tag="viewport" />
            <NavigationViewItem x:Name="ExportNavigationItem" Content="Export" Tag="export" />
        </NavigationView.MenuItems>

        <Grid
            x:Name="ShellLayoutRoot"
            Padding="16"
            ColumnSpacing="16"
            RowSpacing="16">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup>
                    <VisualState x:Name="WideShellState">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="1280" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="ContentColumnDefinition.Width" Value="5*" />
                            <Setter Target="ViewportColumnDefinition.Width" Value="4*" />
                            <Setter Target="ContentFrame.(Grid.Row)" Value="0" />
                            <Setter Target="ContentFrame.(Grid.Column)" Value="0" />
                            <Setter Target="ContentFrame.(Grid.ColumnSpan)" Value="1" />
                            <Setter Target="ViewportRail.(Grid.Row)" Value="0" />
                            <Setter Target="ViewportRail.(Grid.Column)" Value="1" />
                            <Setter Target="ViewportRail.(Grid.ColumnSpan)" Value="1" />
                            <Setter Target="ViewportRail.(Grid.RowSpan)" Value="2" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="StackedShellState">
                        <VisualState.Setters>
                            <Setter Target="ContentColumnDefinition.Width" Value="*" />
                            <Setter Target="ViewportColumnDefinition.Width" Value="0" />
                            <Setter Target="ContentFrame.(Grid.Row)" Value="0" />
                            <Setter Target="ContentFrame.(Grid.Column)" Value="0" />
                            <Setter Target="ContentFrame.(Grid.ColumnSpan)" Value="2" />
                            <Setter Target="ViewportRail.(Grid.Row)" Value="1" />
                            <Setter Target="ViewportRail.(Grid.Column)" Value="0" />
                            <Setter Target="ViewportRail.(Grid.ColumnSpan)" Value="2" />
                            <Setter Target="ViewportRail.(Grid.RowSpan)" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ContentColumnDefinition" Width="5*" />
                <ColumnDefinition x:Name="ViewportColumnDefinition" Width="4*" />
            </Grid.ColumnDefinitions>

            <Frame x:Name="ContentFrame" Grid.Column="0" />

            <Border
                x:Name="ViewportRail"
                Style="{StaticResource PanelBorderStyle}"
                Grid.Column="1"
                Padding="20">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Viewport" />
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="Shared preview surface for model, materials, and rigging workflows."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <Border
                        x:Name="ViewportHostSurface"
                        Style="{StaticResource SubtlePanelBorderStyle}"
                        Grid.Row="1"
                        MinHeight="420"
                        Margin="0,8,0,0"
                        Background="{ThemeResource AppPanelSubtleBackgroundBrush}">
                        <Grid Padding="20">
                            <rendering:ModelViewportControl
                                x:Name="ViewportControl"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch" />
                        </Grid>
                    </Border>

                    <Border
                        x:Name="ViewportDetailsSurface"
                        Style="{StaticResource SubtlePanelBorderStyle}"
                        Grid.Row="2"
                        Margin="0,8,0,0"
                        Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Selection Details" />
                            <TextBlock
                                Text="Hovered and selected scene details will live here without competing with the page-local editing UI."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </NavigationView>
</Window>
