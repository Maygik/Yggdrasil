<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Yggdrasil.Presentation.Pages.ModelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Yggdrasil.Presentation.Models"
    mc:Ignorable="d">

    <Grid>
        <!--Replaces everything when no project is open -->
        <Border x:Name="NoProjectPanel" Style="{StaticResource PanelBorderStyle}" Padding="20">
            <StackPanel Padding="24" Spacing="20">
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Model" />
                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="No project is currently active. Create or open one from the Home page." />
                </StackPanel>
            </StackPanel>
        </Border>

        
        <!--Model Settings-->
        <ScrollViewer x:Name="ModelSettingsPanel" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="24" Spacing="20">
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Model" />
                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="Import a model into the current project and inspect the imported scene structure." />
                </StackPanel>

                <!--Import-->
                <Border Style="{StaticResource PanelBorderStyle}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Import Model" />
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="Choose a source model and import it into the current project." />

                        <Grid ColumnSpacing="12" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Model File" />
                            <Grid Grid.Row="0" Grid.Column="1" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    x:Name="ImportModelPathTextBox"
                                    Grid.Column="0"
                                    PlaceholderText="Choose a model file to import" />
                                <Button
                                    Grid.Column="1"
                                    Content="Browse"
                                    Click="BrowseImportModelButton_Click" />
                            </Grid>

                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Options" />
                            <CheckBox
                                x:Name="AutoMapCheckBox"
                                Grid.Row="1"
                                Grid.Column="1"
                                Content="Automatically map imported bones to rig slots" />

                            <Button
                                x:Name="ImportModelButton"
                                Grid.Row="2"
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                Content="Import Model"
                                Click="ImportModelButton_Click" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!--Scene Summary-->
                <Border x:Name="SceneSummaryPanel" Style="{StaticResource PanelBorderStyle}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Scene Summary" />
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="Imported scene details, per-mesh breakdowns, and material usage." />


                        <!--Top-level scene stats-->
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!--Total Vertices-->
                            <Border Grid.Column="0" Style="{StaticResource SubtlePanelBorderStyle}" Padding="16">
                                <StackPanel Spacing="6">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Total Vertices" />
                                    <TextBlock x:Name="TotalVerticesTextBlock" Style="{StaticResource PageTitleTextStyle}" Text="---" />
                                </StackPanel>
                            </Border>

                            <!--Total Faces-->
                            <Border Grid.Column="1" Style="{StaticResource SubtlePanelBorderStyle}" Padding="16">
                                <StackPanel Spacing="6">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Total Faces" />
                                    <TextBlock x:Name="TotalFacesTextBlock" Style="{StaticResource PageTitleTextStyle}" Text="---" />
                                </StackPanel>
                            </Border>

                            <!--Total Bones-->
                            <Border Grid.Column="2" Style="{StaticResource SubtlePanelBorderStyle}" Padding="16">
                                <StackPanel Spacing="6">
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Bone Count" />
                                    <TextBlock x:Name="TotalBonesTextBlock" Style="{StaticResource PageTitleTextStyle}" Text="---" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        
                        <!--Meshes-->
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource SubtlePanelBorderStyle}" Padding="16">
                                <StackPanel Spacing="12">
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Meshes" />
                                    <TextBlock
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="Click a mesh for details." />

                                    <ItemsControl x:Name="MeshSummaryItemsControl" ItemsSource="{x:Bind MeshSummaryItems, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:MeshSummaryItem">
                                                <Expander Margin="0,0,0,8">
                                                    <Expander.Header>
                                                        <TextBlock Style="{StaticResource BodyStrongTextStyle}" Text="{x:Bind Name}" />
                                                    </Expander.Header>
                                                    <StackPanel Margin="0,12,0,0" Spacing="8">
                                                        <Grid ColumnSpacing="12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource CaptionTextStyle}" Text="Vertices" />
                                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind VertexCount}" />

                                                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource CaptionTextStyle}" Text="Faces" />
                                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind FaceCount}" />
                                                        </Grid>

                                                        <StackPanel Spacing="6">
                                                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="Materials" />
                                                            <ItemsControl ItemsSource="{x:Bind Materials}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="x:String">
                                                                        <TextBlock Margin="12,0,0,4" Text="{x:Bind}" />
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Expander>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            
                            <!--Materials-->
                            <Border Grid.Column="1" Style="{StaticResource SubtlePanelBorderStyle}" Padding="16">
                                <StackPanel Spacing="12">
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Used Materials" />

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="Material Name" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="Usage" />
                                    </Grid>

                                    <ItemsControl x:Name="MaterialUsageItemsControl" ItemsSource="{x:Bind MaterialUsageItems, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:MaterialUsageItem">
                                                <Grid Margin="0,0,0,8" ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="{x:Bind Name}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Style="{StaticResource CaptionTextStyle}"
                                                        Text="{x:Bind MeshUsageCount}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!--Transform Tools-->
                <Border x:Name="ModelToolsPanel" Style="{StaticResource PanelBorderStyle}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="Transform Model" />
                        <TextBlock
                            Style="{StaticResource CaptionTextStyle}"
                            Text="Apply saved scale, rotation, or movement corrections directly to the imported model. Rotation uses degrees, movement uses inches, and these changes persist in the project and affect export output."
                            TextWrapping="WrapWholeWords" />

                        <Border Style="{StaticResource SubtlePanelBorderStyle}" Padding="16">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource BodyStrongTextStyle}"
                                    Text="Scale" />
                                <NumberBox
                                    x:Name="ScaleFactorNumberBox"
                                    Grid.Column="1"
                                    Grid.ColumnSpan="3"
                                    Header="Factor"
                                    Minimum="0.01"
                                    Value="1"
                                    SmallChange="0.1"
                                    SpinButtonPlacementMode="Hidden" />
                                <Button
                                    Grid.Column="4"
                                    MinWidth="112"
                                    VerticalAlignment="Bottom"
                                    Content="Apply Scale"
                                    Click="ApplyScaleButton_Click" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SubtlePanelBorderStyle}" Padding="16">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource BodyStrongTextStyle}"
                                    Text="Rotation" />
                                <NumberBox
                                    x:Name="RotateXNumberBox"
                                    Grid.Column="1"
                                    Header="X"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Hidden" />
                                <NumberBox
                                    x:Name="RotateYNumberBox"
                                    Grid.Column="2"
                                    Header="Y"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Hidden" />
                                <NumberBox
                                    x:Name="RotateZNumberBox"
                                    Grid.Column="3"
                                    Header="Z"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Hidden" />
                                <Button
                                    Grid.Column="4"
                                    MinWidth="112"
                                    VerticalAlignment="Bottom"
                                    Content="Apply Rotation"
                                    Click="ApplyRotationButton_Click" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SubtlePanelBorderStyle}" Padding="16">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource BodyStrongTextStyle}"
                                    Text="Position" />
                                <NumberBox
                                    x:Name="MoveXNumberBox"
                                    Grid.Column="1"
                                    Header="X"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Hidden" />
                                <NumberBox
                                    x:Name="MoveYNumberBox"
                                    Grid.Column="2"
                                    Header="Y"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Hidden" />
                                <NumberBox
                                    x:Name="MoveZNumberBox"
                                    Grid.Column="3"
                                    Header="Z"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Hidden" />
                                <Button
                                    Grid.Column="4"
                                    MinWidth="112"
                                    VerticalAlignment="Bottom"
                                    Content="Apply Move"
                                    Click="ApplyMoveButton_Click" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
