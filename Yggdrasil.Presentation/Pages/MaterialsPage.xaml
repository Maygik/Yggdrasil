<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Yggdrasil.Presentation.Pages.MaterialsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Yggdrasil.Presentation.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Yggdrasil.Presentation.Models"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToBrushConverter
            x:Key="SelectedMaterialBackgroundConverter"
            FalseBrush="Transparent"
            TrueBrush="{ThemeResource AppSelectionBackgroundBrush}" />
        <converters:BooleanToBrushConverter
            x:Key="SelectedMaterialBorderConverter"
            FalseBrush="Transparent"
            TrueBrush="{ThemeResource AppSelectionBorderBrush}" />
    </Page.Resources>

    <Grid>
        <Border x:Name="NoProjectPanel" Style="{StaticResource PanelBorderStyle}" Padding="20">
            <StackPanel Padding="24" Spacing="20">
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Materials" />
                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="No project is currently active. Create or open one from the Home page." />
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid x:Name="MaterialsPanel" Padding="24" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="6">
                <StackPanel Spacing="6">
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Materials" />
                    <TextBlock
                        Style="{StaticResource CaptionTextStyle}"
                        Text="Browse imported materials here while the shared viewport on the right handles preview, hover, and selection feedback." />
                </StackPanel>
            </StackPanel>

            <Grid Grid.Row="1" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Padding="20">
                    <Grid RowSpacing="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Style="{StaticResource SectionTitleTextStyle}" Text="Material List" />

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel MinHeight="600" Spacing="12">
                                <Border
                                    x:Name="NoMaterialsPanel"
                                    Style="{StaticResource SubtlePanelBorderStyle}"
                                    Padding="16">
                                    <TextBlock
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="No imported materials are available yet. Import a model to populate the list."
                                        TextWrapping="WrapWholeWords" />
                                </Border>

                                <ItemsControl
                                    x:Name="MaterialListItemsControl"
                                    ItemsSource="{x:Bind MaterialItems, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:MaterialListItem">
                                            <Border
                                                Margin="0,0,0,8"
                                                Padding="12"
                                                Background="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource SelectedMaterialBackgroundConverter}}"
                                                BorderBrush="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource SelectedMaterialBorderConverter}}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Tag="{x:Bind}"
                                                Tapped="MaterialRow_Tapped"
                                                ToolTipService.ToolTip="{x:Bind Name}">
                                                <TextBlock
                                                    Style="{StaticResource BodyStrongTextStyle}"
                                                    Text="{x:Bind Name}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Padding="20">
                    <Grid RowSpacing="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Style="{StaticResource SectionTitleTextStyle}" Text="Selected Material" />

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel MinHeight="600" Spacing="12">
                                <Border Style="{StaticResource SubtlePanelBorderStyle}" Padding="16">
                                    <TextBlock
                                        x:Name="SelectedMaterialNameTextBlock"
                                        Style="{StaticResource BodyStrongTextStyle}"
                                        Text="Selected material: None" />
                                </Border>

                                <Border Style="{StaticResource SubtlePanelBorderStyle}" Padding="16">
                                    <StackPanel Spacing="8">
                                        <TextBlock Style="{StaticResource BodyStrongTextStyle}" Text="Editor Coming Soon" />
                                        <TextBlock
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="This pane will host the selected material editor. For now, the list on the left is populated from the current scene's imported materials."
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
