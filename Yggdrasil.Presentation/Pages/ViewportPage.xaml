<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Yggdrasil.Presentation.Pages.ViewportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6">
            <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Viewport" />
            <TextBlock
                Style="{StaticResource CaptionTextStyle}"
                Text="Configure shared viewport overlays, helpers, and preview modes in one place."
                TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Padding="20">
                <Grid RowSpacing="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource SectionTitleTextStyle}" Text="Scene Helpers" />

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel MinHeight="600" Spacing="12">
                            <Border Style="{StaticResource SubtlePanelBorderStyle}" Padding="16">
                                <StackPanel Spacing="8">
                                    <ToggleSwitch
                                        x:Name="ShowFloorToggle"
                                        Header="Show floor"
                                        Toggled="ShowFloorToggle_Toggled"
                                        OffContent="Hidden"
                                        OnContent="Visible" />
                                    <TextBlock
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="Shows a ground plane beneath the current scene."
                                        TextWrapping="WrapWholeWords" />

                                    <ToggleSwitch
                                        x:Name="ShowHeightPlaneToggle"
                                        Header="Show height plane"
                                        Toggled="ShowHeightPlaneToggle_Toggled"
                                        OffContent="Hidden"
                                        OnContent="Visible" />
                                    <TextBlock
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="Shows a transparent orange reference plane at the chosen height."
                                        TextWrapping="WrapWholeWords" />

                                    <NumberBox
                                        x:Name="HeightPlaneHeightNumberBox"
                                        Header="Height plane"
                                        SmallChange="1"
                                        SpinButtonPlacementMode="Hidden"
                                        Value="72"
                                        ValueChanged="AlignmentNumberBox_ValueChanged" />
                                    <TextBlock
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="The height plane is rendered as a transparent orange guide. One unit equals one inch."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SubtlePanelBorderStyle}" Padding="16">
                                <StackPanel Spacing="10">
                                    <TextBlock Style="{StaticResource BodyStrongTextStyle}" Text="Preview Alignment" />
                                    <TextBlock
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="These controls only affect the current viewport preview. Use the Model page to apply saved transforms to the imported model."
                                        TextWrapping="WrapWholeWords" />

                                    <NumberBox
                                        x:Name="ModelScaleNumberBox"
                                        Header="Scale"
                                        Minimum="0.01"
                                        Value="1"
                                        SmallChange="0.1"
                                        SpinButtonPlacementMode="Hidden"
                                        ValueChanged="AlignmentNumberBox_ValueChanged" />

                                    <StackPanel Spacing="6">
                                        <TextBlock Style="{StaticResource BodyStrongTextStyle}" Text="Rotation" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <NumberBox
                                                x:Name="ModelRotationXNumberBox"
                                                Grid.Column="0"
                                                Header="X"
                                                SmallChange="1"
                                                SpinButtonPlacementMode="Hidden"
                                                ValueChanged="AlignmentNumberBox_ValueChanged" />
                                            <NumberBox
                                                x:Name="ModelRotationYNumberBox"
                                                Grid.Column="1"
                                                Header="Y"
                                                SmallChange="1"
                                                SpinButtonPlacementMode="Hidden"
                                                ValueChanged="AlignmentNumberBox_ValueChanged" />
                                            <NumberBox
                                                x:Name="ModelRotationZNumberBox"
                                                Grid.Column="2"
                                                Header="Z"
                                                SmallChange="1"
                                                SpinButtonPlacementMode="Hidden"
                                                ValueChanged="AlignmentNumberBox_ValueChanged" />
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Style="{StaticResource BodyStrongTextStyle}" Text="Position" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <NumberBox
                                                x:Name="ModelPositionXNumberBox"
                                                Grid.Column="0"
                                                Header="X"
                                                SmallChange="1"
                                                SpinButtonPlacementMode="Hidden"
                                                ValueChanged="AlignmentNumberBox_ValueChanged" />
                                            <NumberBox
                                                x:Name="ModelPositionYNumberBox"
                                                Grid.Column="1"
                                                Header="Y"
                                                SmallChange="1"
                                                SpinButtonPlacementMode="Hidden"
                                                ValueChanged="AlignmentNumberBox_ValueChanged" />
                                            <NumberBox
                                                x:Name="ModelPositionZNumberBox"
                                                Grid.Column="2"
                                                Header="Z"
                                                SmallChange="1"
                                                SpinButtonPlacementMode="Hidden"
                                                ValueChanged="AlignmentNumberBox_ValueChanged" />
                                        </Grid>
                                    </StackPanel>

                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Padding="20">
                <Grid RowSpacing="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource SectionTitleTextStyle}" Text="Overlays And Preview" />

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel MinHeight="600" Spacing="12">
                            <Border Style="{StaticResource SubtlePanelBorderStyle}" Padding="16">
                                <StackPanel Spacing="8">
                                    <ToggleSwitch
                                        x:Name="ShowBonesToggle"
                                        Header="Show bones"
                                        Toggled="ShowBonesToggle_Toggled"
                                        OffContent="Hidden"
                                        OnContent="Visible" />
                                    <TextBlock
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="Show RGB axes at each bone origin."
                                        TextWrapping="WrapWholeWords" />
                                    <StackPanel Spacing="4">
                                        <TextBlock Style="{StaticResource BodyStrongTextStyle}" Text="Bone axis length" />
                                        <Slider
                                            x:Name="BoneAxisLengthSlider"
                                            Minimum="0.1"
                                            Maximum="12"
                                            Value="2"
                                            SmallChange="0.1"
                                            LargeChange="0.5"
                                            StepFrequency="0.1"
                                            ValueChanged="BoneAxisLengthSlider_ValueChanged" />
                                        <TextBlock
                                            x:Name="BoneAxisLengthValueText"
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="Axis length: 2.0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SubtlePanelBorderStyle}" Padding="16">
                                <StackPanel Spacing="8">
                                    <ToggleSwitch
                                        x:Name="ShowBoneConnectionsToggle"
                                        Header="Show bone connections"
                                        Toggled="ShowBoneConnectionsToggle_Toggled"
                                        OffContent="Hidden"
                                        OnContent="Visible" />
                                    <TextBlock
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="Draw parent-child lines for the active skeleton."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SubtlePanelBorderStyle}" Padding="16">
                                <StackPanel Spacing="8">
                                    <ToggleSwitch
                                        Header="Preview blendshapes"
                                        IsEnabled="False"
                                        OffContent="Coming later"
                                        OnContent="Coming later" />
                                    <TextBlock
                                        Style="{StaticResource CaptionTextStyle}"
                                        Text="Blendshape support will be added in the future."
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
